# Gridlock 2.0 Environment Configuration
# Copy to .env and fill in your values

# API Settings
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4

# CORS Configuration (Production: Restrict to trusted domains)
CORS_ORIGINS=http://localhost:3000,http://localhost:8501,http://localhost:8000
ALLOW_CREDENTIALS=true

# Database (PostgreSQL)
DATABASE_URL=postgresql://gridlock_user:gridlock_password@localhost:5432/gridlock
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=40

# Cache (Redis)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# ML Models
MODEL_ARTIFACTS_DIR=./models/artifacts
EMBEDDING_CACHE_TTL_SECONDS=86400
PREDICTION_CACHE_TTL_SECONDS=604800

# Embedding Configuration
EMBEDDING_MODEL=sentence-transformers/bert-base-multilingual-uncased
EMBEDDING_BATCH_SIZE=32
EMBEDDING_TIMEOUT_MS=10000

# Latency Budgets (milliseconds)
LATENCY_BUDGET_MS=500
DATA_PIPELINE_BUDGET_MS=50
MODULE_A_BUDGET_MS=150
MODULE_B_BUDGET_MS=250
PLAYBOOK_BUDGET_MS=30
SHAP_BUDGET_MS=100

# Data Pipeline Configuration
MAX_BATCH_SIZE=32
VALIDATION_TIMEOUT_MS=5000

# Logging Configuration
LOG_LEVEL=INFO
LOG_DIR=./logs

# Monitoring
ENABLE_METRICS=true
METRICS_PORT=9090

# Spatial-Temporal Graph Configuration
GRAPH_SPATIAL_RADIUS_KM=2
PREDICTION_HORIZON_MINUTES=30
PREDICTION_INTERVAL_MINUTES=5

# Incident Types (comma-separated)
INCIDENT_TYPES=accident,congestion,roadwork,weather,unknown

# Alert Thresholds
VALIDATION_ERROR_RATE_PERCENT=10
LATENCY_PERCENTILE_95_MS=450
LATENCY_PERCENTILE_99_MS=500
MODEL_ACCURACY_DEGRADATION_PERCENT=5

# Dashboard Configuration
# Mapbox API Token (Get from https://account.mapbox.com/auth/signup/)
MAPBOX_API_KEY=pk_test_your_token_here
DASHBOARD_CENTER_LAT=-33.8688
DASHBOARD_CENTER_LNG=151.2093
DASHBOARD_INITIAL_ZOOM=10

# WebSocket Configuration
WS_HEARTBEAT_INTERVAL_SECONDS=30
WS_MAX_MESSAGE_SIZE=1048576

# Development/Production Mode
ENVIRONMENT=development
DEBUG=true
SECRET_KEY=dev-secret-key-change-in-production

# Security Configuration (Production: Use strong values)
API_KEY_LENGTH=32
RATE_LIMIT_REQUESTS_PER_MINUTE=1000
RATE_LIMIT_BLOCK_DURATION_MINUTES=15

# Circuit Breaker Configuration
CIRCUIT_BREAKER_FAILURE_THRESHOLD=0.5
CIRCUIT_BREAKER_FAILURE_COUNT_THRESHOLD=5
CIRCUIT_BREAKER_TIMEOUT_SECONDS=30
CIRCUIT_BREAKER_LATENCY_THRESHOLD_MS=500.0

# Alert Integration (Optional)
PAGERDUTY_INTEGRATION_KEY=
SLACK_WEBHOOK_URL=
EMAIL_SMTP_SERVER=
EMAIL_FROM_ADDRESS=

# SSL/TLS Configuration (Production)
SSL_CERTFILE=
SSL_KEYFILE=

